# PipeWorks Image Generator host-managed service environment for Luminal.

# Keep the backend localhost-only when fronted by nginx.
PIPEWORKS_SERVER_HOST=127.0.0.1
PIPEWORKS_SERVER_PORT=8400

# Host-managed writable paths. Do not write large mutable state into the repo.
PIPEWORKS_MODELS_DIR=/srv/work/pipeworks/runtime/image-generator/models
PIPEWORKS_OUTPUTS_DIR=/srv/work/pipeworks/runtime/image-generator/outputs
PIPEWORKS_GALLERY_DIR=/srv/work/pipeworks/runtime/image-generator/gallery
PIPEWORKS_GALLERY_DB=/srv/work/pipeworks/runtime/image-generator/gallery.json

# Default runtime snippet source for Luminal browser testing.
PW_POLICY_SOURCE_MODE=server_dev
PW_POLICY_DEV_MUD_API_BASE_URL=http://127.0.0.1:18000

# Leave production explicit. Do not copy a stale target here by default.
# PW_POLICY_PROD_MUD_API_BASE_URL=

# Runtime defaults can stay close to the local baseline unless the host needs
# a different posture.
PIPEWORKS_DEVICE=cuda
PIPEWORKS_TORCH_DTYPE=bfloat16
PIPEWORKS_NUM_INFERENCE_STEPS=9
PIPEWORKS_GUIDANCE_SCALE=0.0
PIPEWORKS_DEFAULT_WIDTH=1024
PIPEWORKS_DEFAULT_HEIGHT=1024

# Optional tuning flags.
PIPEWORKS_DISABLE_HTTP_CACHE=false
PIPEWORKS_ENABLE_ATTENTION_SLICING=false
PIPEWORKS_ENABLE_MODEL_CPU_OFFLOAD=false
PIPEWORKS_COMPILE_MODEL=false
PIPEWORKS_ATTENTION_BACKEND=default

# Remote GPU workers are optional. Keep token-bearing config out of the repo.
# PIPEWORKS_GPU_WORKERS=
# PIPEWORKS_DEFAULT_GPU_WORKER_ID=
# PIPEWORKS_WORKER_API_BEARER_TOKENS=[]
